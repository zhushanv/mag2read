APP_NAME=Mag2Read
APP_ENV=development
DEBUG=true

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=mag2read

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

STORAGE_ROOT=backend/storage/tasks
PADDLEX_CACHE_ROOT=backend/storage/paddlex_cache
MAX_UPLOAD_SIZE_MB=100

# Baidu document parsing credentials. Keep real values only in local .env.
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_ACCESS_TOKEN=

# Auth
AUTH_COOKIE_NAME=mag2read_session
AUTH_SESSION_DAYS=14
AUTH_CODE_TTL_MINUTES=5
AUTH_CODE_SEND_INTERVAL_SECONDS=60
AUTH_CODE_SECRET=change-me

# Email login. If SMTP is empty in DEBUG=true, the request-code API returns debug_code.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional OAuth login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=

# Optional captcha.
AUTH_CAPTCHA_ENABLED=false
TURNSTILE_SECRET_KEY=

# ── 翻译服务 ──
# 阿里云机器翻译（推荐，每月 100 万字符免费）
# 在 https://www.aliyun.com/ 开通「机器翻译-通用版」后，
# 在 RAM 访问控制中创建 AccessKey，填入下面三行
ALIYUN_TRANSLATE_ACCESS_KEY=
ALIYUN_TRANSLATE_SECRET_KEY=
ALIYUN_TRANSLATE_REGION=cn-hangzhou

# 百度翻译（备选，每月 200 万字符免费）
# 在 https://fanyi-api.baidu.com/ 申请「通用翻译 API」
# BAIDU_TRANSLATE_APP_ID=
# BAIDU_TRANSLATE_SECRET_KEY=
